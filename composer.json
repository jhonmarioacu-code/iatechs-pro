{
    "name": "iatechs/pro",
    "type": "project",
    "description": "IAtechs Pro enterprise SaaS multi-tenant platform.",
    "keywords": [
        "laravel",
        "saas",
        "multi-tenant",
        "enterprise"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.9",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.47",
        "laravel/sanctum": "^4.0",
        "league/flysystem-aws-s3-v3": "^3.34",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.22",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"$db = getenv('DB_CONNECTION') ?: 'pgsql'; if ($db === 'sqlite' && !file_exists('database/database.sqlite')) touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "analyse": "phpstan analyse --memory-limit=1G",
        "audit:architecture": "@php artisan iatechs:audit-architecture",
        "gate:release": "@php artisan iatechs:gate-release",
        "cache:verify": [
            "@php artisan config:cache --env=testing",
            "@php artisan route:cache --env=testing",
            "@php artisan optimize:clear --env=testing"
        ],
        "format": "pint",
        "migrate:fresh:testing": "@php artisan migrate:fresh --env=testing --force",
        "test": "pest",
        "test:arch": "pest tests/Feature/Architecture",
        "validate:testing": [
            "@migrate:fresh:testing",
            "@test:arch",
            "@audit:architecture",
            "@gate:release",
            "@cache:verify"
        ],
        "validate:release": [
            "@analyse",
            "@test:arch",
            "@audit:architecture",
            "@gate:release"
        ],
        "test:coverage": "pest --coverage --min=80"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
