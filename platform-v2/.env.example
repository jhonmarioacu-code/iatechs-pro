# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iatechs_v2?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
MFA_CHALLENGE_TTL=300s

# Optional local seed values (apps/api/prisma/seed.ts)
SEED_TENANT_SLUG=acme
SEED_TENANT_NAME=Acme Corp
