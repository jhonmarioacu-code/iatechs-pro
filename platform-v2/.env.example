SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Platform Administrator
SEED_ADMIN_ROLE=super_admin
SEED_ADMIN_PERMISSIONS=dashboard:read,crm:read,crm:leads:read,crm:leads:write,repairs:read,repairs:orders:read,repairs:orders:write
