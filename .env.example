APP_NAME="IAtechs Pro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=iatechs_pro
DB_USERNAME=iatechs
DB_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=true

SECURITY_HSTS_ENABLED=true
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=(), payment=(), usb=()"
SECURITY_X_XSS_PROTECTION=0
SECURITY_COOP=same-origin
SECURITY_CORP=same-origin
SECURITY_STRICT_TRANSPORT_SECURITY="max-age=31536000; includeSubDomains; preload"
SECURITY_CONTENT_SECURITY_POLICY="default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss: ws:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"

# Observability SLO/SLA
OBS_PAYMENT_SUCCESS_RATE_MIN=97
OBS_PAYMENT_FAILED_24H_ALERT=5
OBS_PENDING_ONLINE_STALE_MINUTES=30
OBS_PENDING_ONLINE_ALERT=10
OBS_SUBS_PAST_DUE_ALERT=5
OBS_SUBS_CHURN_30D_MAX=5
OBS_EXPORTER_ENABLED=false
OBS_EXPORTER_TOKEN=
OBS_EXPORTER_ALLOWED_IPS=127.0.0.1,::1
OBS_ALERTS_ENABLED=true
OBS_ALERTS_EMAIL_ENABLED=true
OBS_ALERTS_EMAIL_RECIPIENTS=
OBS_ALERTS_SLACK_ENABLED=true
OBS_ALERTS_SLACK_WEBHOOK_URL=${LOG_SLACK_WEBHOOK_URL}
OBS_ALERTS_COOLDOWN_MINUTES=30
OBS_ALERTS_CHECK_INTERVAL_MINUTES=5
OBS_EXPORTER_TOKEN_FILE=./docker/observability/secrets/obs_exporter_token.example
OBS_ALERTS_SLACK_WEBHOOK_FILE=./docker/observability/secrets/slack_webhook_url.example
PROMETHEUS_RETENTION_TIME=15d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin_password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
HORIZON_PREFIX=iatechs

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=log
MAIL_MAILER_TRANSACTIONAL=log
TRANSACTIONAL_EMAIL_PROVIDER=ses
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_EHLO_DOMAIN=
MAIL_FAILOVER_MAILERS=ses,postmark,smtp,log
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
POSTMARK_TOKEN=
SENDGRID_API_KEY=
MAIL_FROM_ADDRESS="noreply@iatechs.test"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=

# Realtime / Broadcast
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Pusher (optional fallback)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

GROQ_API_KEY=
AZURE_OPENAI_RESPONSES_ENDPOINT=https://<azure-resource>.services.ai.azure.com/api/projects/<project>/agents/<agent>/endpoint/protocols/openai/responses
AZURE_OPENAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=

# Payments / External commerce
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CURRENCY=COP

# CDN / DNS
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Auth / Tokens (optional by implementation)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
JWT_SECRET=
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=

# OAuth social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT=common

VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
